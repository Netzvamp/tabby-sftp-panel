# --- settings ---
msgid "When you open a file (double-click)"
msgstr "Al abrir un archivo (doble clic)"

msgid "Start folder"
msgstr "Carpeta inicial"

msgid "Folder the panel opens on connect. Absolute path (e.g. /var/www), or ~ for your home directory."
msgstr "Carpeta que el panel abre al conectar. Ruta absoluta (p. ej. /var/www) o ~ para tu directorio personal."

msgid "Use a default editor for opening files"
msgstr "Usar un editor predeterminado para abrir archivos"

msgid "Off: files open with the OS default app (normal Tabby behavior). On: pick one editor used for every file you open. Turning this on tries to auto-detect your editor (Windows only); you can also Browse or type the path. A blank path behaves like \"off\"."
msgstr "Desactivado: los archivos se abren con la app predeterminada del sistema (comportamiento normal de Tabby). Activado: elige un editor para cada archivo que abras. Al activarlo se intenta detectar tu editor automáticamente (solo Windows); también puedes examinar o escribir la ruta. Una ruta vacía equivale a «desactivado»."

msgid "Editor path"
msgstr "Ruta del editor"

msgid "Executable used for every file you open. Blank = OS default app."
msgstr "Ejecutable usado para cada archivo que abras. Vacío = app predeterminada del sistema."

msgid "(blank = OS default)"
msgstr "(vacío = predeterminado del SO)"

msgid "Browse…"
msgstr "Examinar…"

msgid "Warn when opening large files"
msgstr "Avisar al abrir archivos grandes"

msgid "Show a confirmation before opening a file larger than this many MB in the editor (guards against mis-clicking a binary). 0 = never warn."
msgstr "Mostrar una confirmación antes de abrir en el editor un archivo mayor que estos MB (evita abrir un binario por error). 0 = no avisar nunca."

msgid "Panel side"
msgstr "Lado del panel"

msgid "Auto-show log on activity"
msgstr "Mostrar registro automáticamente al haber actividad"

msgid "Reveals the log list at the bottom of the panel whenever a transfer starts or a message is logged. While the list is shown, the Tabby transfers popup is hidden."
msgstr "Muestra la lista de registro en la parte inferior del panel cuando empieza una transferencia o se registra un mensaje. Mientras se muestra la lista, el popup de transferencias de Tabby permanece oculto."

msgid "Toggle hotkey"
msgstr "Tecla de acceso rápido"

msgid "Set under Settings → Hotkeys → \"Focus SFTP Panel\""
msgstr "Configúralo en Ajustes → Teclas rápidas → «Enfocar SFTP Panel»"

msgid "Show vertical label on collapsed strip"
msgstr "Mostrar la etiqueta vertical en la tira contraída"

msgid "The \"SFTP Panel\" text on the hover strip (unpinned). Off makes the strip thinner."
msgstr "El texto \"SFTP Panel\" en la tira flotante (sin fijar). Desactivado hace la tira más estrecha."
