# --- settings ---
msgid "When you open a file (double-click)"
msgstr "Ao abrir um arquivo (clique duplo)"

msgid "Start folder"
msgstr "Pasta inicial"

msgid "Folder the panel opens on connect. Absolute path (e.g. /var/www), or ~ for your home directory."
msgstr "Pasta que o painel abre ao conectar. Caminho absoluto (ex.: /var/www) ou ~ para seu diretório pessoal."

msgid "Use a default editor for opening files"
msgstr "Usar um editor padrão para abrir arquivos"

msgid "Off: files open with the OS default app (normal Tabby behavior). On: pick one editor used for every file you open. Turning this on tries to auto-detect your editor (Windows only); you can also Browse or type the path. A blank path behaves like \"off\"."
msgstr "Desligado: os arquivos abrem com o app padrão do sistema (comportamento normal do Tabby). Ligado: escolha um editor usado para cada arquivo aberto. Ao ligar, tenta detectar seu editor automaticamente (somente Windows); você também pode procurar ou digitar o caminho. Um caminho vazio equivale a «desligado»."

msgid "Editor path"
msgstr "Caminho do editor"

msgid "Executable used for every file you open. Blank = OS default app."
msgstr "Executável usado para cada arquivo aberto. Vazio = app padrão do sistema."

msgid "(blank = OS default)"
msgstr "(vazio = padrão do SO)"

msgid "Browse…"
msgstr "Procurar…"

msgid "Warn when opening large files"
msgstr "Avisar ao abrir arquivos grandes"

msgid "Show a confirmation before opening a file larger than this many MB in the editor (guards against mis-clicking a binary). 0 = never warn."
msgstr "Mostrar uma confirmação antes de abrir no editor um arquivo maior que esta quantidade de MB (evita clicar em um binário por engano). 0 = nunca avisar."

msgid "Panel side"
msgstr "Lado do painel"

msgid "Auto-show log on activity"
msgstr "Mostrar registro automaticamente em atividade"

msgid "Reveals the log list at the bottom of the panel whenever a transfer starts or a message is logged. While the list is shown, the Tabby transfers popup is hidden."
msgstr "Exibe a lista de registro na parte inferior do painel sempre que uma transferência começa ou uma mensagem é registrada. Enquanto a lista é exibida, o popup de transferências do Tabby fica oculto."

msgid "Toggle hotkey"
msgstr "Tecla de atalho de alternância"

msgid "Set under Settings → Hotkeys → \"Focus SFTP Panel\""
msgstr "Defina em Configurações → Teclas de atalho → «Focar SFTP Panel»"

msgid "Show vertical label on collapsed strip"
msgstr "Mostrar rótulo vertical na faixa recolhida"

msgid "The \"SFTP Panel\" text on the hover strip (unpinned). Off makes the strip thinner."
msgstr "O texto \"SFTP Panel\" na faixa flutuante (não fixada). Desativado deixa a faixa mais fina."
