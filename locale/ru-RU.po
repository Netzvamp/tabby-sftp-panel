msgstr "Обновить"

msgid "New file"
msgstr "Новый файл"

msgid "Hide dotfiles"
msgstr "Скрыть скрытые файлы"

msgid "Show dotfiles"
msgstr "Показать скрытые файлы"

msgid "Upload files"
msgstr "Загрузить файлы"

msgid "Upload folder"
msgstr "Загрузить папку"

msgid "Filter..."
msgstr "Фильтр..."

