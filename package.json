{
  "name": "tabby-sftp-panel",
  "version": "0.1.0",
  "description": "A standalone SFTP file browser panel for Tabby with resizable/sortable columns, overlay-or-dock positioning, multi-select, and edit-on-open. Coexists with the built-in panel.",
  "keywords": ["tabby-plugin"],
  "main": "dist/index.js",
  "scripts": {
    "build": "webpack --progress --color",
    "watch": "webpack --progress --color --watch",
    "test": "tsx --test src/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "files": ["dist"],
  "author": "Robert Lieback",
  "license": "MIT",
  "repository": "github:Netzvamp/tabby-sftp-panel",
  "homepage": "https://github.com/Netzvamp/tabby-sftp-panel#readme",
  "bugs": "https://github.com/Netzvamp/tabby-sftp-panel/issues",
  "peerDependencies": {
    "@angular/common": "^15",
    "@angular/core": "^15",
    "@angular/forms": "^15",
    "@ng-bootstrap/ng-bootstrap": "^14",
    "rxjs": "^7",
    "tabby-core": "*",
    "tabby-ssh": "*",
    "tabby-settings": "*"
  },
  "devDependencies": {
    "@angular/common": "^15.2.6",
    "@angular/core": "^15.2.6",
    "@angular/forms": "^15.2.6",
    "@ng-bootstrap/ng-bootstrap": "^14.2.0",
    "@types/node": "20.3.1",
    "json-loader": "^0.5.7",
    "po-gettext-loader": "^1.0.0",
    "rxjs": "^7.8.0",
    "tabby-core": "*",
    "tabby-ssh": "*",
    "tabby-settings": "*",
    "ts-loader": "^9.4.2",
    "tsx": "^4.7.0",
    "typescript": "~4.9.5",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
